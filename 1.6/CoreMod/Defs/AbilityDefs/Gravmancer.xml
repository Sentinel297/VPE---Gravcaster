<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_CrushSTNL</defName>
		<label>Crush</label>
		<description>Create a small gravitational anomaly within the target, dealing 10 to 15 blunt damage. Using Crush on an enemy affected by "Singularity" will turn Crush into Collapse, creating an explosion on the target.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/Crush</iconPath>
		<castTime>60</castTime>
		<chance>0</chance>
		<durationTime>0</durationTime>
		<targetMode>Pawn</targetMode>
		<range>14.9</range>
		<hasAoE>false</hasAoE>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_Crush</abilityClass>
		<targetingParameters>
			<canTargetLocations>false</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
			<canTargetPawns>true</canTargetPawns>
			<canTargetHumans>true</canTargetHumans>
			<canTargetItems>false</canTargetItems>
			<canTargetMechs>true</canTargetMechs>
			<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>1</level>
				<order>1</order>
				<psyfocusCost>0.05</psyfocusCost>
				<entropyGain>15</entropyGain>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<!-- Level 2 -->
<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_Gravcaster_Gravshield_STNL</defName>
	<label>Gravshield</label>
	<description>Protects the target creature with a gravitational anomaly that will deflect projectiles back to the attacker.</description>
	<iconPath>UI_GravmancerSTNL/Abilities/TheHellIsThatNaming</iconPath>
	<castTime>60</castTime>
	<durationTime>12500</durationTime>
	<durationTimeStatFactors>
		<PsychicSensitivity>1</PsychicSensitivity>
	</durationTimeStatFactors>
	<chance>0</chance>
	<targetMode>Pawn</targetMode>
	<targetingParameters>
		<canTargetLocations>false</canTargetLocations>
		<canTargetSelf>true</canTargetSelf>
		<canTargetAnimals>true</canTargetAnimals>
		<canTargetPawns>true</canTargetPawns>
		<canTargetHumans>true</canTargetHumans>
		<!-- <canTargetItems>false</canTargetItems> -->
		<canTargetMechs>true</canTargetMechs>
		<!-- <mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable> -->
	</targetingParameters>
	<range>16.9</range>
	<hasAoE>false</hasAoE>
	<castSound>PsycastPsychicPulse</castSound>
	<needsTicking>true</needsTicking>
	<abilityClass>VPE_Gravmancer.Ability_Gravshield</abilityClass>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_GravmancerSTNL</path>
			<level>2</level>
			<order>2</order>
			<psyfocusCost>0.07</psyfocusCost>
			<entropyGain>40</entropyGain>
			<prerequisites>
				<li>VPE_TelekineticSatelliteSTNL</li>
			</prerequisites>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_TelekineticSatelliteSTNL</defName>
		<label>Telekinetic Satellites</label>
		<description>Lift nearby small stones and make them orbit around you, these stones will seek out enemies and hit them as fast as bullets.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/Sat</iconPath>
		<castTime>60</castTime>
		<durationTime>0</durationTime>
		<chance>0</chance>
		<targetMode>Self</targetMode>
		<range>-1</range>
		<hasAoE>false</hasAoE>
		<castSound>PsycastPsychicPulse</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_TelekineticSatellite</abilityClass>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>2</level>
				<order>2</order>
				<psyfocusCost>0.15</psyfocusCost>
				<entropyGain>15</entropyGain>
				<prerequisites>
					<li>VPE_CrushSTNL</li>
				</prerequisites>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_IncreasedGravitySTNL</defName>
		<label>Increase Gravity</label>
		<description>Induce an artificial gravity field on the target, rendering them unable to stand.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/Grav</iconPath>
		<castTime>240</castTime>
		<chance>0</chance>
		<durationTime>30000</durationTime>
		<targetMode>Pawn</targetMode>
		<range>14.9</range>
		<castSound>Bestowing_Start</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<fleckOnTarget>PsycastAreaEffect</fleckOnTarget>
		<targetingParameters>
			<canTargetLocations>False</canTargetLocations>
			<canTargetSelf>True</canTargetSelf>
			<canTargetAnimals>True</canTargetAnimals>
			<canTargetPawns>True</canTargetPawns>
			<canTargetHumans>True</canTargetHumans>
			<canTargetMechs>True</canTargetMechs>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>2</level>
				<order>2</order>
				<psyfocusCost>0.12</psyfocusCost>
				<entropyGain>15</entropyGain>
				<prerequisites>
					<li>VPE_TelekineticSatelliteSTNL</li>
				</prerequisites>
			</li>
			<li Class="VEF.Abilities.AbilityExtension_Hediff">
				<hediff>GravityEnhancedSTNL</hediff>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<!-- Level 3 -->
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_GravimpactSTNL</defName>
		<label>Gravimpact</label>
		<description>Rapidly compress and expand gravity on itself, causing a phenomenon similar to a detonation. Then hurl yourself to the target location.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/IMP</iconPath>
		<castTime>60</castTime>
		<durationTime>60000</durationTime>
		<targetMode>Pawn</targetMode>
		<range>20.9</range>
		<radius>2.9</radius>
		<chance>0</chance>
		<hasAoE>false</hasAoE>
		<castSound>PsycastPsychicEffect</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_BlinkExplosion</abilityClass>
		<targetingParameters>
			<canTargetLocations>true</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
			<canTargetPawns>true</canTargetPawns>
			<canTargetHumans>true</canTargetHumans>
			<canTargetItems>true</canTargetItems>
			<canTargetMechs>true</canTargetMechs>
			<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>3</level>
				<order>1</order>
				<psyfocusCost>0.05</psyfocusCost>
				<entropyGain>40</entropyGain>
				<prerequisites>
					<li>VPE_TelekineticSatelliteSTNL</li>
				</prerequisites>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<!-- Level 4 -->
