	<!-- Level 5 -->
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_SingularitySTNL</defName>
		<label>Singularity</label>
		<description>Create a miniature gravitational anomaly at the target location, it will pull enemies in and inflict damage to them. Using Crush on pawns affected by this ability will turn it into Crush: Collapse, causing an explosion.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/SING</iconPath>
		<castTime>180</castTime>
		<durationTime>1500</durationTime>
		<targetMode>Pawn</targetMode>
		<range>18.9</range>
		<chance>0</chance>
		<radius>5</radius>
		<hasAoE>false</hasAoE>
		<castSound>Explosion_Vaporize</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_Singularity</abilityClass>
		<targetingParameters>
			<canTargetLocations>true</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
			<canTargetPawns>true</canTargetPawns>
			<canTargetHumans>true</canTargetHumans>
			<canTargetItems>true</canTargetItems>
			<canTargetMechs>false</canTargetMechs>
			<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>5</level>
				<order>1</order>
				<psyfocusCost>0.16</psyfocusCost>
				<entropyGain>75</entropyGain>
				<prerequisites>
					<li>VPE_FallingSkySTNL</li>
				</prerequisites>
			</li>
			<li Class="VPE_Gravmancer.AbilityExtension_Singularity">
				<duration>1500</duration>
				<interval>25</interval>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<!-- Level 6 -->
	
	<!-- Have to keep this defname since some people might have that skill, else this blows up! -->
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_ShipBreakerSTNL</defName>
		<label>Greater Gravshield</label>
		<description>Form a gravitational anomaly around the caster that will protect nearby allied creatures from ranged attacks. \n\nThis anomaly requires a lot of concentration to maintain, causing the caster to be unable to dissipate neural heat while the shield is active.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/LargeShield</iconPath>
		<abilityClass>VPE_Gravmancer.Ability_GreaterGravshield</abilityClass>
		<castTime>90</castTime>
		<chance>0</chance>
		<targetMode>Self</targetMode>
		<range>-1</range>
		<radius>6.9</radius>
		<hasAoE>false</hasAoE>
		<castSound>PsycastPsychicPulse</castSound>
		<needsTicking>true</needsTicking>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>6</level>
				<order>2</order>
				<psyfocusCost>0.12</psyfocusCost>
				<entropyGain>0</entropyGain>
				<prerequisites>
					<li>VPE_SingularitySTNL</li>
				</prerequisites>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	
		<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_AnnihilationSTNL</defName>
		<label>Annihilation</label>
		<description>Forces a low orbit asteroid to come crashing down onto the target world tile, the process will destroy both the target and an asteroid on the world map.</description>
		<iconPath>World/WorldObjects/Expanding/GravshipLaunchSite</iconPath>
		<castTime>120</castTime>
		<targetMode>Tile</targetMode>
		<range>9999</range>
		<chance>0</chance>
		<worldTargeting>true</worldTargeting>
		<showGizmoOnWorldView>true</showGizmoOnWorldView>
		<castSound>Explosion_Thump</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_DestroySite</abilityClass>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>5</level>
				<order>3</order>
				<psyfocusCost>0.60</psyfocusCost>
				<entropyGain>250</entropyGain>
				<prerequisites>
					<li>VPE_ShipBreakerSTNL</li>
				</prerequisites>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
</Defs>

