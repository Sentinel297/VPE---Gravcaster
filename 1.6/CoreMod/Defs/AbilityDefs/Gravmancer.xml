		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>4</level>
				<order>3</order>
				<psyfocusCost>0.12</psyfocusCost>
				<entropyGain>80</entropyGain>
				<prerequisites>
					<li>VPE_GravimpactSTNL</li>
				</prerequisites>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_FallingSkySTNL</defName>
		<label>Meteor Strike</label>
		<description>Alter the gravity of a nearby asteroid field, this change in trajectory will cause meteors to rain down on the target location.</description>
		<iconPath>World/WorldObjects/Expanding/AsteroidMine</iconPath>
		<castTime>180</castTime>
		<durationTime>60000</durationTime>
		<targetMode>Pawn</targetMode>
		<range>35.9</range>
		<radius>0</radius>
		<chance>0</chance>
		<hasAoE>false</hasAoE>
		<castSound>VPE_SkipGate_Cast</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_SummonMeteorites</abilityClass>
		<targetingParameters>
			<canTargetLocations>true</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
