<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_CrushSTNL</defName>
		<label>Crush</label>
		<description>Create a small gravitational anomaly within the target, dealing 10 to 15 blunt damage. Using Crush on an enemy affected by "Singularity" will turn Crush into Collapse, creating an explosion on the target.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/Crush</iconPath>
		<castTime>60</castTime>
		<chance>0</chance>
		<durationTime>0</durationTime>
		<targetMode>Pawn</targetMode>
		<range>14.9</range>
		<hasAoE>false</hasAoE>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_Crush</abilityClass>
		<targetingParameters>
			<canTargetLocations>false</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
			<canTargetPawns>true</canTargetPawns>
			<canTargetHumans>true</canTargetHumans>
			<canTargetItems>false</canTargetItems>
			<canTargetMechs>true</canTargetMechs>
			<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
				<level>1</level>
				<order>1</order>
				<psyfocusCost>0.05</psyfocusCost>
				<entropyGain>15</entropyGain>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
	<!-- Level 2 -->
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_TelekineticSatelliteSTNL</defName>
		<label>Telekinetic Satellites</label>
		<description>Lift nearby small stones and make them orbit around you, these stones will seek out enemies and hit them as fast as bullets.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/Sat</iconPath>
		<castTime>60</castTime>
		<durationTime>0</durationTime>
		<chance>0</chance>
		<targetMode>Self</targetMode>
		<range>-1</range>
		<hasAoE>false</hasAoE>
		<castSound>PsycastPsychicPulse</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_TelekineticSatellite</abilityClass>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>VPE_GravmancerSTNL</path>
