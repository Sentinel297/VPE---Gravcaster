		<castTime>120</castTime>
		<targetMode>Tile</targetMode>
		<range>9999</range>
		<chance>0</chance>
		<worldTargeting>true</worldTargeting>
		<showGizmoOnWorldView>true</showGizmoOnWorldView>
		<castSound>Explosion_Thump</castSound>
