	</VEF.Abilities.AbilityDef>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>VPE_FallingSkyALTSTNL</defName>
		<label>Sky Drop</label>
		<description>Deviate a meteor full of resources from its original course, sending it to a location of your choosing instead.</description>
		<iconPath>World/WorldObjects/Expanding/ResourceAsteroid</iconPath>
		<castTime>180</castTime>
		<durationTime>0</durationTime>
		<targetMode>Pawn</targetMode>
		<chance>0</chance>
		<range>18.9</range>
		<radius>4</radius>
		<hasAoE>false</hasAoE>
		<castSound>VPE_SkipGate_Cast</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_SpawnMeteorite</abilityClass>
		<targetingParameters>
			<canTargetLocations>true</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
			<canTargetAnimals>true</canTargetAnimals>
			<canTargetPawns>true</canTargetPawns>
