		<defName>VPE_MoltenPullSTNL</defName>
		<label>Molten Pull</label>
		<description>Send a multitude of asteroids filled with melting rocks hurling towards the target, resulting in the affected area becoming a temporary lava field.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/MOLT</iconPath>
		<castTime>180</castTime>
		<durationTime>0</durationTime>
		<targetMode>Pawn</targetMode>
		<chance>0</chance>
		<range>40.9</range>
		<radius>0</radius>
		<hasAoE>false</hasAoE>
		<castSound>VPE_SkipGate_Cast</castSound>
		<needsTicking>true</needsTicking>
		<abilityClass>VPE_Gravmancer.Ability_SpawnVolcanicDebris</abilityClass>
		<targetingParameters>
			<canTargetLocations>true</canTargetLocations>
			<canTargetSelf>false</canTargetSelf>
