		<description>Create a miniature gravitational anomaly at the target location, it will pull enemies in and inflict damage to them. Using Crush on pawns affected by this ability will turn it into Crush: Collapse, causing an explosion.</description>
		<iconPath>UI_GravmancerSTNL/Abilities/SING</iconPath>
		<castTime>180</castTime>
		<durationTime>1500</durationTime>
		<targetMode>Pawn</targetMode>
		<range>18.9</range>
		<chance>0</chance>
		<radius>5</radius>
